<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FrontOfficeERP.ViewModels"
             x:Class="FrontOfficeERP.Views.DutyMasterPage"
             x:DataType="vm:DutyMasterViewModel"
             Title="Duty Master"
             BackgroundColor="#f0f2f5">

    <Grid RowDefinitions="Auto,*,Auto" Padding="24,24,24,0" RowSpacing="16">

        <!-- Toolbar -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12">
            <Button Text="+ New Duty"
                    Command="{Binding NewDutyCommand}"
                    BackgroundColor="#1a237e"
                    TextColor="White"
                    CornerRadius="6" />
            <Button Text="Refresh"
                    Command="{Binding LoadDutiesCommand}"
                    BackgroundColor="#2e7d32"
                    TextColor="White"
                    CornerRadius="6" />
        </HorizontalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="16">

            <!-- Duty List -->
            <Border StrokeShape="RoundRectangle 8" Stroke="#e0e0e0" BackgroundColor="White">
                <CollectionView ItemsSource="{Binding Duties}" SelectionMode="None">
                    <CollectionView.Header>
                        <Grid ColumnDefinitions="80,*,120,80,80,80" Padding="12,8" BackgroundColor="#1a237e">
                            <Label Grid.Column="0" Text="Code" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="1" Text="Duty Name" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="2" Text="Shift Type" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="3" Text="Start" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="4" Text="End" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="5" Text="Actions" TextColor="White" FontAttributes="Bold" FontSize="12" />
                        </Grid>
                    </CollectionView.Header>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:Object">
                            <Grid ColumnDefinitions="80,*,120,80,80,80" Padding="12,6">
                                <Label Grid.Column="0" Text="{Binding DutyCode}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding DutyName}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding ShiftType}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="3" Text="{Binding StartTime}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="4" Text="{Binding EndTime}" FontSize="12" VerticalOptions="Center" />
                                <Button Grid.Column="5"
                                        Text="Edit"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DutyMasterViewModel}}, Path=EditDutyCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#1565c0"
                                        TextColor="White"
                                        FontSize="10"
                                        HeightRequest="28"
                                        CornerRadius="4"
                                        Padding="8,0" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <!-- Edit Panel -->
            <Border Grid.Column="1"
                    StrokeShape="RoundRectangle 8"
                    Stroke="#e0e0e0"
                    BackgroundColor="White"
                    Padding="20"
                    WidthRequest="320"
                    IsVisible="{Binding IsEditing}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Duty Details" FontSize="18" FontAttributes="Bold" TextColor="#1a237e" />
                    <BoxView HeightRequest="1" Color="#e0e0e0" />

                    <Label Text="Duty Code" FontSize="12" TextColor="#666" />
                    <Entry Text="{Binding DutyCode}" Placeholder="E.g. MRN" />

                    <Label Text="Duty Name" FontSize="12" TextColor="#666" />
                    <Entry Text="{Binding DutyName}" Placeholder="E.g. Morning Shift" />

                    <Label Text="Description" FontSize="12" TextColor="#666" />
                    <Editor Text="{Binding Description}" HeightRequest="60" Placeholder="Description" />

                    <Label Text="Start Time" FontSize="12" TextColor="#666" />
                    <Entry Text="{Binding StartTime}" Placeholder="HH:mm" />

                    <Label Text="End Time" FontSize="12" TextColor="#666" />
                    <Entry Text="{Binding EndTime}" Placeholder="HH:mm" />

                    <Label Text="Shift Type" FontSize="12" TextColor="#666" />
                    <Picker ItemsSource="{Binding ShiftTypes}" SelectedItem="{Binding ShiftType}" />

                    <HorizontalStackLayout Spacing="8">
                        <CheckBox IsChecked="{Binding IsActive}" />
                        <Label Text="Active" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
                        <Button Text="Save"
                                Command="{Binding SaveDutyCommand}"
                                BackgroundColor="#2e7d32"
                                TextColor="White"
                                CornerRadius="6" />
                        <Button Grid.Column="1"
                                Text="Cancel"
                                Command="{Binding CancelEditCommand}"
                                BackgroundColor="#757575"
                                TextColor="White"
                                CornerRadius="6" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <ActivityIndicator Grid.RowSpan="2" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#1a237e" VerticalOptions="Center" HorizontalOptions="Center" />

        <!-- Mandatory Footer -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                Stroke="#e0e0e0"
                Padding="8">
            <Label Text="copyright @2026 Develop By Chetan"
                   FontSize="12"
                   TextColor="#666"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </Border>
    </Grid>
</ContentPage>
