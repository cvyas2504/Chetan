<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FrontOfficeERP.ViewModels"
             x:Class="FrontOfficeERP.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="Login"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f0f2f5">

    <Grid RowDefinitions="*,Auto">
    <Grid Grid.Row="0" VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="400">
        <Border StrokeShape="RoundRectangle 12"
                Stroke="#e0e0e0"
                BackgroundColor="White"
                Padding="40"
                Shadow="{Shadow Brush=#20000000, Offset='2,4', Radius=12}">
            <VerticalStackLayout Spacing="16">

                <!-- Logo / Title -->
                <Label Text="FrontOffice ERP"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#1a237e"
                       HorizontalOptions="Center" />

                <Label Text="Duty Roster Management System"
                       FontSize="14"
                       TextColor="#666"
                       HorizontalOptions="Center" />

                <BoxView HeightRequest="1" Color="#e0e0e0" Margin="0,8" />

                <!-- Username -->
                <Label Text="Username" FontSize="13" TextColor="#333" />
                <Border StrokeShape="RoundRectangle 6" Stroke="#ccc" Padding="8,4">
                    <Entry Text="{Binding Username}"
                           Placeholder="Enter username"
                           ReturnType="Next" />
                </Border>

                <!-- Password -->
                <Label Text="Password" FontSize="13" TextColor="#333" />
                <Border StrokeShape="RoundRectangle 6" Stroke="#ccc" Padding="8,4">
                    <Entry Text="{Binding Password}"
                           Placeholder="Enter password"
                           IsPassword="True"
                           ReturnType="Done"
                           ReturnCommand="{Binding LoginCommand}" />
                </Border>

                <!-- Error Message -->
                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                       HorizontalOptions="Center" />

                <!-- Login Button -->
                <Button Text="Sign In"
                        Command="{Binding LoginCommand}"
                        BackgroundColor="#1a237e"
                        TextColor="White"
                        FontAttributes="Bold"
                        HeightRequest="44"
                        CornerRadius="6"
                        Margin="0,8,0,0" />

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#1a237e"
                                   HorizontalOptions="Center" />

                <Label Text="Default: admin / admin123"
                       FontSize="11"
                       TextColor="#999"
                       HorizontalOptions="Center"
                       Margin="0,8,0,0" />

            </VerticalStackLayout>
        </Border>
    </Grid>

    <!-- Mandatory Footer -->
    <Border Grid.Row="1"
            BackgroundColor="White"
            Stroke="#e0e0e0"
            Padding="8">
        <Label Text="copyright @2026 Develop By Chetan"
               FontSize="12"
               TextColor="#666"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center" />
    </Border>

    </Grid>
</ContentPage>
