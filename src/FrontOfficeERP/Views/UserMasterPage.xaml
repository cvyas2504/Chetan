<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FrontOfficeERP.ViewModels"
             x:Class="FrontOfficeERP.Views.UserMasterPage"
             x:DataType="vm:UserMasterViewModel"
             Title="User Master"
             BackgroundColor="#f0f2f5">

    <Grid RowDefinitions="Auto,*" Padding="24" RowSpacing="16">

        <HorizontalStackLayout Grid.Row="0" Spacing="12">
            <Button Text="+ New User"
                    Command="{Binding NewUserCommand}"
                    BackgroundColor="#1a237e" TextColor="White" CornerRadius="6" />
            <Button Text="Refresh"
                    Command="{Binding LoadUsersCommand}"
                    BackgroundColor="#2e7d32" TextColor="White" CornerRadius="6" />
        </HorizontalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="16">

            <Border StrokeShape="RoundRectangle 8" Stroke="#e0e0e0" BackgroundColor="White">
                <CollectionView ItemsSource="{Binding Users}" SelectionMode="None">
                    <CollectionView.Header>
                        <Grid ColumnDefinitions="*,*,*,80,80,80" Padding="12,8" BackgroundColor="#1a237e">
                            <Label Grid.Column="0" Text="Username" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="1" Text="Full Name" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="2" Text="Email" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="3" Text="Role" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="4" Text="Active" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="5" Text="Actions" TextColor="White" FontAttributes="Bold" FontSize="12" />
                        </Grid>
                    </CollectionView.Header>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:Object">
                            <Grid ColumnDefinitions="*,*,*,80,80,80" Padding="12,6">
                                <Label Grid.Column="0" Text="{Binding Username}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding FullName}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding Email}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="3" Text="{Binding Role}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="4" Text="{Binding IsActive}" FontSize="12" VerticalOptions="Center" />
                                <Button Grid.Column="5"
                                        Text="Edit"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:UserMasterViewModel}}, Path=EditUserCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#1565c0" TextColor="White" FontSize="10" HeightRequest="28" CornerRadius="4" Padding="8,0" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Border Grid.Column="1" StrokeShape="RoundRectangle 8" Stroke="#e0e0e0" BackgroundColor="White"
                    Padding="20" WidthRequest="320" IsVisible="{Binding IsEditing}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="User Details" FontSize="18" FontAttributes="Bold" TextColor="#1a237e" />
                    <BoxView HeightRequest="1" Color="#e0e0e0" />

                    <Label Text="Username" FontSize="12" TextColor="#666" />
                    <Entry Text="{Binding Username}" Placeholder="Username" />

                    <Label Text="Password" FontSize="12" TextColor="#666" />
                    <Entry Text="{Binding Password}" Placeholder="Password (new users only)" IsPassword="True" />

                    <Label Text="Full Name" FontSize="12" TextColor="#666" />
                    <Entry Text="{Binding FullName}" Placeholder="Full name" />

                    <Label Text="Email" FontSize="12" TextColor="#666" />
                    <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email" />

                    <Label Text="Role" FontSize="12" TextColor="#666" />
                    <Picker ItemsSource="{Binding Roles}" SelectedItem="{Binding Role}" />

                    <HorizontalStackLayout Spacing="8">
                        <CheckBox IsChecked="{Binding IsActive}" />
                        <Label Text="Active" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
                        <Button Text="Save" Command="{Binding SaveUserCommand}"
                                BackgroundColor="#2e7d32" TextColor="White" CornerRadius="6" />
                        <Button Grid.Column="1" Text="Cancel" Command="{Binding CancelEditCommand}"
                                BackgroundColor="#757575" TextColor="White" CornerRadius="6" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <ActivityIndicator Grid.RowSpan="2" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#1a237e" VerticalOptions="Center" HorizontalOptions="Center" />
    </Grid>
</ContentPage>
