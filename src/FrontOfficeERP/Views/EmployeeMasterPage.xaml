<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FrontOfficeERP.ViewModels"
             x:Class="FrontOfficeERP.Views.EmployeeMasterPage"
             x:DataType="vm:EmployeeMasterViewModel"
             Title="Employee Master"
             BackgroundColor="#f0f2f5">

    <Grid RowDefinitions="Auto,*" Padding="24" RowSpacing="16">

        <!-- Toolbar -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12">
            <Button Text="+ New Employee"
                    Command="{Binding NewEmployeeCommand}"
                    BackgroundColor="#1a237e"
                    TextColor="White"
                    CornerRadius="6" />
            <Button Text="Refresh"
                    Command="{Binding LoadEmployeesCommand}"
                    BackgroundColor="#2e7d32"
                    TextColor="White"
                    CornerRadius="6" />
        </HorizontalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="16">

            <!-- Employee List -->
            <Border StrokeShape="RoundRectangle 8" Stroke="#e0e0e0" BackgroundColor="White">
                <CollectionView ItemsSource="{Binding Employees}" SelectionMode="None">
                    <CollectionView.Header>
                        <Grid ColumnDefinitions="80,*,*,*,*,100" Padding="12,8" BackgroundColor="#1a237e">
                            <Label Grid.Column="0" Text="Code" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="1" Text="Name" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="2" Text="Department" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="3" Text="Designation" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="4" Text="Phone" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Grid.Column="5" Text="Actions" TextColor="White" FontAttributes="Bold" FontSize="12" />
                        </Grid>
                    </CollectionView.Header>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:Object">
                            <Grid ColumnDefinitions="80,*,*,*,*,100" Padding="12,6">
                                <Label Grid.Column="0" Text="{Binding EmployeeCode}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding FullName}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding Department}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="3" Text="{Binding Designation}" FontSize="12" VerticalOptions="Center" />
                                <Label Grid.Column="4" Text="{Binding Phone}" FontSize="12" VerticalOptions="Center" />
                                <HorizontalStackLayout Grid.Column="5" Spacing="4">
                                    <Button Text="Edit"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeMasterViewModel}}, Path=EditEmployeeCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#1565c0"
                                            TextColor="White"
                                            FontSize="10"
                                            HeightRequest="28"
                                            CornerRadius="4"
                                            Padding="8,0" />
                                </HorizontalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <!-- Edit Panel -->
            <Border Grid.Column="1"
                    StrokeShape="RoundRectangle 8"
                    Stroke="#e0e0e0"
                    BackgroundColor="White"
                    Padding="20"
                    WidthRequest="350"
                    IsVisible="{Binding IsEditing}">
                <ScrollView>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Employee Details" FontSize="18" FontAttributes="Bold" TextColor="#1a237e" />
                        <BoxView HeightRequest="1" Color="#e0e0e0" />

                        <Label Text="Employee Code" FontSize="12" TextColor="#666" />
                        <Entry Text="{Binding EmployeeCode}" Placeholder="E.g. EMP001" />

                        <Label Text="First Name" FontSize="12" TextColor="#666" />
                        <Entry Text="{Binding FirstName}" Placeholder="First name" />

                        <Label Text="Last Name" FontSize="12" TextColor="#666" />
                        <Entry Text="{Binding LastName}" Placeholder="Last name" />

                        <Label Text="Department" FontSize="12" TextColor="#666" />
                        <Entry Text="{Binding Department}" Placeholder="Department" />

                        <Label Text="Designation" FontSize="12" TextColor="#666" />
                        <Entry Text="{Binding Designation}" Placeholder="Designation" />

                        <Label Text="Email" FontSize="12" TextColor="#666" />
                        <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email" />

                        <Label Text="Phone" FontSize="12" TextColor="#666" />
                        <Entry Text="{Binding Phone}" Placeholder="Phone" Keyboard="Telephone" />

                        <Label Text="Date of Joining" FontSize="12" TextColor="#666" />
                        <DatePicker Date="{Binding DateOfJoining}" />

                        <HorizontalStackLayout Spacing="8">
                            <CheckBox IsChecked="{Binding IsActive}" />
                            <Label Text="Active" VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
                            <Button Text="Save"
                                    Command="{Binding SaveEmployeeCommand}"
                                    BackgroundColor="#2e7d32"
                                    TextColor="White"
                                    CornerRadius="6" />
                            <Button Grid.Column="1"
                                    Text="Cancel"
                                    Command="{Binding CancelEditCommand}"
                                    BackgroundColor="#757575"
                                    TextColor="White"
                                    CornerRadius="6" />
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <ActivityIndicator Grid.RowSpan="2" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#1a237e" VerticalOptions="Center" HorizontalOptions="Center" />
    </Grid>
</ContentPage>
