<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FrontOfficeERP.ViewModels"
             x:Class="FrontOfficeERP.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard"
             BackgroundColor="#f0f2f5">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24">

            <!-- Welcome Header -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{Binding WelcomeMessage}"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#1a237e" />
                <Button Grid.Column="1"
                        Text="Logout"
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="#c62828"
                        TextColor="White"
                        CornerRadius="6"
                        HeightRequest="36"
                        Padding="16,0" />
            </Grid>

            <BoxView HeightRequest="1" Color="#e0e0e0" />

            <!-- Stats Cards -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">

                <!-- Employees Card -->
                <Border Grid.Column="0" StrokeShape="RoundRectangle 8" Stroke="#e0e0e0"
                        BackgroundColor="White" Padding="20"
                        Shadow="{Shadow Brush=#10000000, Offset='1,2', Radius=6}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Total Employees" FontSize="13" TextColor="#666" />
                        <Label Text="{Binding TotalEmployees}" FontSize="32" FontAttributes="Bold" TextColor="#1a237e" />
                    </VerticalStackLayout>
                </Border>

                <!-- Duties Card -->
                <Border Grid.Column="1" StrokeShape="RoundRectangle 8" Stroke="#e0e0e0"
                        BackgroundColor="White" Padding="20"
                        Shadow="{Shadow Brush=#10000000, Offset='1,2', Radius=6}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Active Duties" FontSize="13" TextColor="#666" />
                        <Label Text="{Binding TotalDuties}" FontSize="32" FontAttributes="Bold" TextColor="#2e7d32" />
                    </VerticalStackLayout>
                </Border>

                <!-- Today Card -->
                <Border Grid.Column="2" StrokeShape="RoundRectangle 8" Stroke="#e0e0e0"
                        BackgroundColor="White" Padding="20"
                        Shadow="{Shadow Brush=#10000000, Offset='1,2', Radius=6}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Today's Roster" FontSize="13" TextColor="#666" />
                        <Label Text="{Binding TodayRosterCount}" FontSize="32" FontAttributes="Bold" TextColor="#e65100" />
                    </VerticalStackLayout>
                </Border>

                <!-- Week Card -->
                <Border Grid.Column="3" StrokeShape="RoundRectangle 8" Stroke="#e0e0e0"
                        BackgroundColor="White" Padding="20"
                        Shadow="{Shadow Brush=#10000000, Offset='1,2', Radius=6}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="This Week" FontSize="13" TextColor="#666" />
                        <Label Text="{Binding WeekRosterCount}" FontSize="32" FontAttributes="Bold" TextColor="#6a1b9a" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Navigation Modules -->
            <Label Text="Modules" FontSize="18" FontAttributes="Bold" TextColor="#333" Margin="0,8,0,0" />

            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="16">

                <!-- Duty Roster -->
                <Border Grid.Row="0" Grid.Column="0" StrokeShape="RoundRectangle 8"
                        Stroke="#e0e0e0" BackgroundColor="White" Padding="24"
                        Shadow="{Shadow Brush=#10000000, Offset='1,2', Radius=6}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="dutyroster" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="&#x1F4CB;" FontSize="36" HorizontalOptions="Center" />
                        <Label Text="Duty Roster" FontSize="16" FontAttributes="Bold" TextColor="#1a237e" HorizontalOptions="Center" />
                        <Label Text="Manage weekly/monthly duty schedules" FontSize="12" TextColor="#666" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Employee Master -->
                <Border Grid.Row="0" Grid.Column="1" StrokeShape="RoundRectangle 8"
                        Stroke="#e0e0e0" BackgroundColor="White" Padding="24"
                        Shadow="{Shadow Brush=#10000000, Offset='1,2', Radius=6}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="employees" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="&#x1F465;" FontSize="36" HorizontalOptions="Center" />
                        <Label Text="Employee Master" FontSize="16" FontAttributes="Bold" TextColor="#2e7d32" HorizontalOptions="Center" />
                        <Label Text="Manage employee records" FontSize="12" TextColor="#666" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Duty Master -->
                <Border Grid.Row="0" Grid.Column="2" StrokeShape="RoundRectangle 8"
                        Stroke="#e0e0e0" BackgroundColor="White" Padding="24"
                        Shadow="{Shadow Brush=#10000000, Offset='1,2', Radius=6}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="dutymaster" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="&#x1F4D1;" FontSize="36" HorizontalOptions="Center" />
                        <Label Text="Duty Master" FontSize="16" FontAttributes="Bold" TextColor="#e65100" HorizontalOptions="Center" />
                        <Label Text="Define duty types and shifts" FontSize="12" TextColor="#666" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Excel Compare -->
                <Border Grid.Row="1" Grid.Column="0" StrokeShape="RoundRectangle 8"
                        Stroke="#e0e0e0" BackgroundColor="White" Padding="24"
                        Shadow="{Shadow Brush=#10000000, Offset='1,2', Radius=6}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="excelcompare" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="&#x1F4CA;" FontSize="36" HorizontalOptions="Center" />
                        <Label Text="Excel Compare" FontSize="16" FontAttributes="Bold" TextColor="#6a1b9a" HorizontalOptions="Center" />
                        <Label Text="Compare and merge Excel files" FontSize="12" TextColor="#666" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- User Master -->
                <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle 8"
                        Stroke="#e0e0e0" BackgroundColor="White" Padding="24"
                        Shadow="{Shadow Brush=#10000000, Offset='1,2', Radius=6}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="users" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="&#x1F511;" FontSize="36" HorizontalOptions="Center" />
                        <Label Text="User Master" FontSize="16" FontAttributes="Bold" TextColor="#00695c" HorizontalOptions="Center" />
                        <Label Text="Manage user accounts and access" FontSize="12" TextColor="#666" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Login History -->
                <Border Grid.Row="1" Grid.Column="2" StrokeShape="RoundRectangle 8"
                        Stroke="#e0e0e0" BackgroundColor="White" Padding="24"
                        Shadow="{Shadow Brush=#10000000, Offset='1,2', Radius=6}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToCommand}" CommandParameter="loginhistory" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="&#x1F4DD;" FontSize="36" HorizontalOptions="Center" />
                        <Label Text="Login History" FontSize="16" FontAttributes="Bold" TextColor="#37474f" HorizontalOptions="Center" />
                        <Label Text="View login audit trail" FontSize="12" TextColor="#666" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#1a237e" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
